# Figma Sites SEO Proxy - Configuration
# Copy this file to .env and update with your actual values
# 
# IMPORTANT: This is the ONLY file you need to edit for configuration!
# - Wrangler automatically loads these variables
# - The prerender script reads them via dotenv
# - No need to edit wrangler.toml [vars] section

# Your Figma Sites subdomain (where Figma is hosted)
FIGMA_SITE_URL=https://web.yourdomain.com

# Your main domain (what users see)
MAIN_DOMAIN=https://yourdomain.com

# Cloudflare KV Namespace ID
# Get this from: npx wrangler kv:namespace create "PRERENDER_CACHE"
# Also paste this ID in wrangler.toml [[kv_namespaces]] id field
KV_NAMESPACE_ID=your-kv-namespace-id

# Debug mode (true/false) - set to false in production
DEBUG=false

# Cloudflare Account ID (optional - for wrangler commands)
# Find with: npx wrangler whoami
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# Cloudflare API Token (optional - for CI/CD)
# Get from: https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=your-api-token

# ─── BigCal Feature Toggle ────────────────────────────────────────────────────
# Set BIGCAL_ENABLED=true to activate the BigCal calendar trial feature.
# When enabled, requests to /bigcal/* are routed to the BigCal Figma site.
# When disabled (default), /bigcal/* redirects to the main domain.
BIGCAL_ENABLED=false

# BigCal Figma Sites subdomain (where the BigCal Figma site is hosted)
# Required when BIGCAL_ENABLED=true
BIGCAL_FIGMA_URL=https://web-bigcal.yourdomain.com

# BigCal canonical domain (what users see for BigCal pages)
# Defaults to MAIN_DOMAIN if not set
BIGCAL_SITE_URL=https://bigcal.yourdomain.com
